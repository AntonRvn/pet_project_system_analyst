{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "target_system": { "enum": ["accounts_department", "tax_service"] },
    "event_type": { "const": "deposit_activated" },
    "deposit_data": {
      "type": "object",
      "properties": {
        "deposit_account_id": { "type": "string" },
        "client_full_name": { "type": "string" },
        "client_tax_id": { "type": "string" },
        "amount": { "type": "number" },
        "term_months": { "type": "integer" },
        "rate": { "type": "number" },
        "activation_date": { "type": "string", "format": "date" }
      },
      "required": ["deposit_account_id", "client_full_name", "client_tax_id", "amount", "term_months", "rate", "activation_date"]
    }
  },
  "required": ["target_system", "event_type", "deposit_data"]
}

Пример
{
  "target_system": "tax_service",
  "event_type": "deposit_activated",
  "deposit_data": {
    "deposit_account_id": "40817810987654321098",
    "client_full_name": "Петрова Елена Дмитриевна",
    "client_tax_id": "987654321098",
    "amount": 150000,
    "term_months": 18,
    "rate": 9.25,
    "activation_date": "2026-04-07"
  }
}