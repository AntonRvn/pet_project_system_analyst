{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "contract_id": { "type": "string" },
    "client_full_name": { "type": "string" },
    "deposit_terms": {
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "term_months": { "type": "integer" },
        "rate": { "type": "number" },
        "refill_allowed": { "type": "boolean" }
      },
      "required": ["amount", "term_months", "rate", "refill_allowed"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "status": { "enum": ["pending_signature"] }
  },
  "required": ["contract_id", "client_full_name", "deposit_terms", "status"]
}

Пример
{
  "contract_id": "CTR-DEP-20260407-001",
  "client_id": "CL12345678",
  "contract_data": {
    "amount": 100000,
    "term_months": 12,
    "rate": 8.5,
    "refill_allowed": true
  },
  "signed_at": "2026-04-07T10:30:00Z",
  "signature_method": "electronic_esignature"
}