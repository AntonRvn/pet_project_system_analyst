{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "client_id": { "type": "string", "pattern": "^[A-Z0-9]{8,16}$" },
    "requested_fields": {
      "type": "array",
      "items": { "enum": ["full_name", "passport_data", "phone", "email"] },
      "minItems": 1
    }
  },
  "required": ["client_id", "requested_fields"],
  "additionalProperties": false
}

Пример
{
  "client_id": "CL98765432",
  "requested_fields": ["Иванов Петр Алексеевич", "1234567890", "89800010203", "email@mail.ru"]
}