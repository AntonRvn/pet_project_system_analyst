{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "deposit_account_id": { "type": "string" },
    "source_account_id": { "type": "string" },
    "required_amount": { "type": "number", "minimum": 0.01 },
    "client_id": { "type": "string" }
  },
  "required": ["deposit_account_id", "source_account_id", "required_amount", "client_id"]
}

Пример
{
  "deposit_account_id": "40817810987654321098",
  "source_account_id": "40817810555555555555",
  "required_amount": 150000,
  "client_id": "CL98765432"
}

